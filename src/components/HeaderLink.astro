---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, ...props } = Astro.props;

const { pathname } = Astro.url;
const currentPath = pathname.endsWith('/') ? pathname : `${pathname}/`;
const currentParts = currentPath.match(/[^\/]+/g) ?? [];
const hrefPath = typeof href === 'string' && href.endsWith('/') ? href : `${href}/`;
const hrefParts = typeof href === 'string' ? hrefPath.match(/[^\/]+/g) ?? [] : [];
const isActive = hrefPath === currentPath || (
	hrefParts.length > 1 &&
	currentParts[0] === hrefParts[0] &&
	currentParts[1] === hrefParts[1]
);
---

<a
	href={href}
	class:list={[
		"p-5 font-medium hover:bg-stone-200 hover:transition decoration-none color-initial",
		{ active: isActive },
	]}
	{...props}
>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		background-color: rgb(231 229 228);
	}
</style>
