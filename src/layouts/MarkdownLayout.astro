---
import BaseLayout from "./BaseLayout.astro";
import type { Locale } from "../i18n";

import "../styles/markdown.css";

interface Props {
	title?: string;
	description?: string;
	locale?: Locale;
	alternateUrls?: { locale: string; href: string }[];
}

const { title, description, locale, alternateUrls } = Astro.props;
---

<BaseLayout title={title} description={description} locale={locale} alternateUrls={alternateUrls}>
	<article class="py-20">
		<div class="article mx-auto max-w-3xl">
			<slot />
		</div>
	</article>
</BaseLayout>
